<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash theme for Android 12+ (API 31+) -->
    <!-- This allows us to override the default "Icon in Circle" look -->
    <style name="SplashTheme" parent="AppTheme">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/logo_vector</item>
        <item name="android:windowSplashScreenAnimationDuration">1000</item>
        
        <!-- Keep windowBackground for compatibility / good measure, though 12 uses the above -->
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>
</resources>

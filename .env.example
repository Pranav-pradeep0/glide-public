# SubDL API (subtitle search/download)
SUBDL_API_KEY=your_subdl_api_key_here
SUBDL_API_URL=https://api.subdl.com/api/v1/subtitles
SUBDL_DOWNLOAD_URL=https://dl.subdl.com

# OMDB API (movie/show metadata, 1000 free requests/day)
OMDB_API_KEY=your_omdb_api_key_here
OMDB_API_URL=https://www.omdbapi.com

# Groq API (speech-to-text & chat)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_CHAT_API_URL=https://api.groq.com/openai/v1/chat/completions

# GitHub Releases (update checks)
GITHUB_OWNER=your_github_org_or_user
GITHUB_REPO=your_repo_name
# Optional override (if you want a custom endpoint)
# GITHUB_RELEASES_URL=https://api.github.com/repos/OWNER/REPO/releases/latest

# Stallion (OTA updates)
STALLION_PROJECT_ID=your_stallion_project_id
STALLION_APP_TOKEN=your_stallion_app_token
